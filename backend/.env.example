# =============================================================================
# Speaking — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# All values below are placeholders — replace with real secrets in production.
# =============================================================================

# -- Application --
# APP_NAME=Speaking
# DEBUG=false

# -- Environment --
# ENV=development  # development / production / testing

# =============================================================================
# -- Required: Database & Redis --
# =============================================================================
DATABASE_URL=postgresql+asyncpg://speaking:speaking_dev@localhost:5432/speaking
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# -- Required: JWT Authentication --
# =============================================================================
JWT_SECRET=your-jwt-secret-here
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080  # 7 days

# =============================================================================
# -- Required: AI Provider (OpenAI-compatible API) --
# =============================================================================
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
# OPENAI_MODEL=agnes-2.0-flash

# =============================================================================
# -- Optional: Translation Engine (pluggable) --
# =============================================================================
# TRANSLATION_ENGINE=agnes            # hy_mt2 | qwen | agnes | custom
# TRANSLATION_FALLBACK_ENGINE=        # optional: fallback engine on primary failure
# TRANSLATION_BATCH_SIZE=20           # subtitles per LLM call
# TRANSLATION_HYMT2_API_KEY=          # iFLYTEK API key (shared for Hy-MT2 & Qwen)
# TRANSLATION_QWEN_API_KEY=           # iFLYTEK API key (shared for Hy-MT2 & Qwen)
# TRANSLATION_CUSTOM_BASE_URL=        # custom OpenAI-compatible endpoint
# TRANSLATION_CUSTOM_API_KEY=         # custom endpoint API key
# TRANSLATION_CUSTOM_MODEL=           # custom endpoint model name

# =============================================================================
# -- Optional: Local media storage --
# =============================================================================
# LOCAL_MEDIA_PATH=./media

# =============================================================================
# -- Optional: Upload settings --
# =============================================================================
# UPLOAD_TEMP_DIR=./uploads
# MAX_UPLOAD_FILE_SIZE=524288000  # 500MB

# =============================================================================
# -- Optional: Video CDN (Alibaba Cloud OSS) --
# =============================================================================
# OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY=your-oss-access-key
# OSS_SECRET_KEY=your-oss-secret-key
# OSS_CDN_DOMAIN=cdn.speaking-app.com         # CDN domain serving the bucket
# OSS_UPLOAD_ENABLED=false                     # Set true to upload transcoded videos to OSS
# OSS_PREFIX=videos/                           # Path prefix in bucket
# OSS_CLEANUP_LOCAL=false                      # Delete local transcoded files after OSS upload

# =============================================================================
# -- Optional: Payment (Alipay) --
# =============================================================================
# ALIPAY_APP_ID=your-alipay-app-id
# ALIPAY_PUBLIC_KEY=your-alipay-public-key
# ALIPAY_PRIVATE_KEY=your-alipay-private-key

# =============================================================================
# -- Optional: Payment (WeChat Pay) --
# =============================================================================
# WECHAT_MCH_ID=your-wechat-merchant-id
# WECHAT_API_V3_KEY=your-wechat-api-v3-key
# WECHAT_SERIAL_NO=your-wechat-cert-serial-no
# PAYMENT_VERIFY_SIGNATURE=false

# =============================================================================
# -- Optional: YouTube Data API v3 for comment extraction --
# =============================================================================
# YOUTUBE_API_KEY=your-youtube-api-key

# =============================================================================
# -- Optional: YouTube cookies for restricted/private videos --
# =============================================================================
# To get cookies: python get_youtube_cookies.py --from-session
# Or manually: playwright-cli open https://youtube.com --persistent
#             playwright-cli state-save youtube_cookies.txt
# YOUTUBE_COOKIES_PATH=./youtube_cookies.txt

# =============================================================================
# -- Optional: Proxy for yt-dlp / AI API --
# =============================================================================
# HTTP_PROXY=http://127.0.0.1:7890

# =============================================================================
# -- Optional: Speech transcription (faster-whisper) --
# =============================================================================
# WHISPER_MODEL_PATH=base          # faster-whisper model path: tiny/base/small/medium/large-v3
# WHISPER_MODEL_SIZE=base          # model size alias
# WHISPER_DEVICE=auto              # auto/cpu/cuda
# WHISPER_COMPUTE_TYPE=int8        # int8/float16/float32
# WHISPER_CHUNK_DURATION=600       # long video chunk duration (seconds)
# WHISPER_MAX_CONCURRENT_CHUNKS=2  # concurrent transcription chunks

# =============================================================================
# -- Optional: WhisperX alignment & VAD --
# =============================================================================
# WHISPERX_ALIGN_MODEL=           # Override alignment model; empty = auto by language
# WHISPERX_VAD_METHOD=pyannote    # pyannote or silero
# WHISPERX_BATCH_SIZE=8           # Inference batch size (1 for CPU, 8-16 for GPU)

# =============================================================================
# -- Optional: Transcription temp directory --
# =============================================================================
# TRANSCRIPTION_TEMP_DIR=./tmp/transcription

# =============================================================================
# -- Optional: Frontend URL for CORS --
# =============================================================================
# FRONTEND_URL=http://localhost:3000

# =============================================================================
# -- Optional: CSP connect-src domains (space-separated) --
# =============================================================================
# CSP_CONNECT_DOMAINS=https://api.openai.com https://gateway.agnes.ai

# =============================================================================
# -- Optional: Observability --
# =============================================================================
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=INFO

# =============================================================================
# -- Optional: SMTP / Email (for password reset) --
# =============================================================================
# If SMTP_HOST is empty, password reset links are logged to stdout instead of sending email.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_TLS=true
# PASSWORD_RESET_EXPIRE_MINUTES=30
