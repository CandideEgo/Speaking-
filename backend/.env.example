# =============================================================================
# Speaking — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# All values below are placeholders — replace with real secrets in production.
# =============================================================================

# -- Application --
# APP_NAME=Speaking
# DEBUG=false

# -- Environment --
# ENV=development  # development / production / testing

# =============================================================================
# -- Required: Database & Redis --
# =============================================================================
DATABASE_URL=postgresql+asyncpg://speaking:speaking_dev@localhost:5432/speaking
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# -- Required: JWT Authentication --
# =============================================================================
JWT_SECRET=your-jwt-secret-here
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080  # 7 days

# =============================================================================
# -- Required: AI Provider (OpenAI-compatible API) --
# =============================================================================
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
# OPENAI_MODEL=agnes-2.0-flash

# =============================================================================
# -- Optional: Translation Engine (pluggable) --
# =============================================================================
# TRANSLATION_ENGINE=agnes            # hy_mt2 | qwen | agnes | custom
# TRANSLATION_FALLBACK_ENGINE=        # optional: fallback engine on primary failure
# TRANSLATION_BATCH_SIZE=20           # subtitles per LLM call
# TRANSLATION_HYMT2_API_KEY=          # iFLYTEK API key (shared for Hy-MT2 & Qwen)
# TRANSLATION_QWEN_API_KEY=           # iFLYTEK API key (shared for Hy-MT2 & Qwen)
# TRANSLATION_CUSTOM_BASE_URL=        # custom OpenAI-compatible endpoint
# TRANSLATION_CUSTOM_API_KEY=         # custom endpoint API key
# TRANSLATION_CUSTOM_MODEL=           # custom endpoint model name

# =============================================================================
# -- Optional: Local media storage --
# =============================================================================
# LOCAL_MEDIA_PATH=./media

# =============================================================================
# -- Optional: Upload settings --
# =============================================================================
# UPLOAD_TEMP_DIR=./uploads
# MAX_UPLOAD_FILE_SIZE=524288000  # 500MB

# =============================================================================
# -- Optional: Video CDN (Alibaba Cloud OSS) --
# =============================================================================
# OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY=your-oss-access-key
# OSS_SECRET_KEY=your-oss-secret-key
# OSS_CDN_DOMAIN=cdn.speaking-app.com         # CDN domain serving the bucket
# OSS_UPLOAD_ENABLED=false                     # Set true to upload transcoded videos to OSS
# OSS_PREFIX=videos/                           # Path prefix in bucket
# OSS_CLEANUP_LOCAL=false                      # Delete local transcoded files after OSS upload
# -- Remote-GPU transcription: OSS raw-media transfer (cloud uploads local
#    uploads to OSS and hands the GPU worker a signed URL).
# OSS_RAW_PREFIX=video/raw                     # OSS key prefix for staged raw uploads
# OSS_RAW_BUCKET_PUBLIC=false                  # false = private bucket, use signed URLs
# OSS_SIGNED_URL_EXPIRY=7200                   # signed-URL lifetime (≥ max queue wait + transcribe)

# =============================================================================
# -- Alibaba Cloud SMS (Dypnsapi) — phone login verification code --
# =============================================================================
# When SMS_LOGIN_ENABLED=false (or AK/SK empty), the sms_service uses a dev
# fake: it logs the code and accepts the fixed value "1234" — no Aliyun calls.
# Set SMS_LOGIN_ENABLED=true + AK/SK to send real SMS via Dypnsapi.
# SMS_LOGIN_ENABLED=false
# ALIYUN_SMS_ACCESS_KEY=your-aliyun-access-key
# ALIYUN_SMS_SECRET_KEY=your-aliyun-secret-key
# ALIYUN_SMS_SIGN_NAME=速通互联验证码
# ALIYUN_SMS_TEMPLATE_CODE=100001

# =============================================================================
# -- Remote-GPU transcription pipeline (cloud side) --
# =============================================================================
# Video subtitles are transcribed on a separate GPU machine (remote Celery
# worker on the transcription_gpu queue) and POSTed back here. The cloud runs
# zero Whisper for the video pipeline.
# TRANSCRIPTION_CALLBACK_URL=https://api.speaking-app.com/api/v1/internal/transcription/callback
# TRANSCRIPTION_CALLBACK_SECRET=shared-secret                  # authenticates inbound callbacks
# TRANSCRIPTION_GPU_QUEUE_NAME=transcription_gpu
# TRANSCRIPTION_CALLBACK_TIMEOUT=30                            # seconds per HTTP attempt
# TRANSCRIPTION_CALLBACK_MAX_RETRIES=5                         # 5xx / connection retries
# VIDEO_TRANSCRIBE_TIMEOUT=7200                                # watchdog: fail stuck "transcribing" (s)


# =============================================================================
# -- Optional: Payment (Alipay) --
# =============================================================================
# ALIPAY_APP_ID=your-alipay-app-id
# ALIPAY_PUBLIC_KEY=your-alipay-public-key
# ALIPAY_PRIVATE_KEY=your-alipay-private-key

# =============================================================================
# -- Optional: Payment (WeChat Pay) --
# =============================================================================
# WECHAT_MCH_ID=your-wechat-merchant-id
# WECHAT_API_V3_KEY=your-wechat-api-v3-key
# WECHAT_SERIAL_NO=your-wechat-cert-serial-no
# PAYMENT_VERIFY_SIGNATURE=false

# =============================================================================
# -- Optional: YouTube cookies for yt-dlp admin downloads --
# =============================================================================
# To get cookies: python get_youtube_cookies.py --from-session
# Or manually: playwright-cli open https://youtube.com --persistent
#             playwright-cli state-save youtube_cookies.txt
# YOUTUBE_COOKIES_PATH=./youtube_cookies.txt

# =============================================================================
# -- Optional: Proxy for yt-dlp / AI API --
# =============================================================================
# HTTP_PROXY=http://127.0.0.1:7890

# =============================================================================
# -- Optional: Speech transcription (faster-whisper) --
# =============================================================================
# WHISPER_MODEL_PATH=base          # faster-whisper model path: tiny/base/small/medium/large-v3
# WHISPER_MODEL_SIZE=base          # model size alias
# WHISPER_DEVICE=auto              # auto/cpu/cuda
# WHISPER_COMPUTE_TYPE=int8        # int8/float16/float32
# WHISPER_CHUNK_DURATION=600       # long video chunk duration (seconds)
# WHISPER_MAX_CONCURRENT_CHUNKS=2  # concurrent transcription chunks

# =============================================================================
# -- Optional: WhisperX alignment & VAD --
# =============================================================================
# WHISPERX_ALIGN_MODEL=           # Override alignment model; empty = auto by language
# WHISPERX_VAD_METHOD=pyannote    # pyannote or silero
# WHISPERX_BATCH_SIZE=8           # Inference batch size (1 for CPU, 8-16 for GPU)
# WHISPER_LANGUAGE=               # ASR language; empty = auto-detect per audio (needed for
                                 # non-English content). Set e.g. "en" to force & skip detection.
# WHISPER_ENGINE=whisperx         # Engine: whisperx (VAD+align, best) or faster_whisper (fallback)
# WHISPERX_MODEL=                 # WhisperX model; empty = reuse WHISPER_MODEL_PATH
# WHISPERX_COMPUTE_TYPE=          # WhisperX compute override; empty = derive from device (float16 on GPU).
#                                 # Set int8 on OOM-prone GPUs (~half VRAM, small quality loss) to avoid
#                                 # falling back to faster-whisper (which skips alignment → giant subtitle lines).
# WHISPER_PUNCTUATION_RESTORE=true  # Restore punctuation before alignment (true=on).
#                                 # No-op on turbo; set false to skip model load + ~2s/chunk.
#                                 # Keep true for base/small models (their raw output lacks punctuation).

# =============================================================================
# -- Optional: Transcription temp directory --
# =============================================================================
# TRANSCRIPTION_TEMP_DIR=./tmp/transcription

# =============================================================================
# -- Optional: Frontend URL for CORS --
# =============================================================================
# FRONTEND_URL=http://localhost:3000

# =============================================================================
# -- Optional: CSP connect-src domains (space-separated) --
# =============================================================================
# CSP_CONNECT_DOMAINS=https://api.openai.com https://gateway.agnes.ai

# =============================================================================
# -- Optional: Observability --
# =============================================================================
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=INFO

# =============================================================================
# -- Optional: SMTP / Email (for password reset) --
# =============================================================================
# If SMTP_HOST is empty, password reset links are logged to stdout instead of sending email.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_TLS=true
# PASSWORD_RESET_EXPIRE_MINUTES=30

# =============================================================================
# -- Remote GPU transcription worker (runs on the local GPU machine) --
# =============================================================================
# This machine connects to the CLOUD Redis as a remote Celery worker and
# consumes only the transcription_gpu queue. It needs NO DATABASE_URL and NO
# OSS credentials (media arrives via source URL or OSS signed URL; subtitles
# leave via HTTP callback).
#
# Run:  celery -A app.tasks.celery_app worker -Q transcription_gpu --concurrency=1
#
# REDIS_URL=redis://:CLOUD_REDIS_PASSWORD@127.0.0.1:6379/0   # via SSH tunnel to cloud
# WHISPER_ENGINE=whisperx
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# WHISPERX_COMPUTE_TYPE=float16
# WHISPER_MODEL_PATH=large-v3                # CTranslate2 dir / size name on the GPU box
# WHISPER_LANGUAGE=en                        # empty = auto-detect
# TRANSCRIPTION_TEMP_DIR=/var/speaking/transcription_temp
# HTTP_PROXY=                                # only if the GPU box needs egress proxy
# YOUTUBE_COOKIES_PATH=                      # only for age/region-locked streaming URLs
# TRANSCRIPTION_CALLBACK_URL=https://api.speaking-app.com/api/v1/internal/transcription/callback
# TRANSCRIPTION_CALLBACK_SECRET=shared-secret
