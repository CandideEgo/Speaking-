# GPU worker local config (DEV-FLOW 2026-07 Phase B3).
#
# Copy to ".env.gpu-worker" (gitignored) and fill the CHANGE_ME values.
# scripts/run_gpu_worker.ps1 loads this into the process environment before
# starting the Celery GPU worker.
#
# Fetch the two secrets from the cloud (do NOT commit them):
#   ssh seeword "grep -E '^(REDIS_PASSWORD|TRANSCRIPTION_CALLBACK_SECRET)=' ~/seeword/.env"

# --- Broker: cloud Redis, reached via the SSH tunnel (gpu_worker_tunnel.ps1) ---
# Tunnel maps local 16379 -> cloud 127.0.0.1:6379. 16379 (not 6379) avoids
# clashing with the local dev Redis started by docker-compose.dev.yml.
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:16379/0
TRANSCRIPTION_GPU_QUEUE_NAME=transcription_gpu

# --- WhisperX (local GPU) ---
WHISPER_ENGINE=whisperx
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPERX_COMPUTE_TYPE=float16
WHISPER_MODEL_PATH=large-v3
WHISPER_LANGUAGE=en
WHISPERX_VAD_METHOD=silero
WHISPERX_BATCH_SIZE=8
WHISPER_PUNCTUATION_RESTORE=true
WHISPER_MAX_CONCURRENT_CHUNKS=2

# --- Callback: POST the transcription result back to the cloud ---
# Routed via the public domain (HK VPS terminates SSL -> cloud backend).
TRANSCRIPTION_CALLBACK_URL=https://seeword.top/api/v1/internal/transcription/callback
TRANSCRIPTION_CALLBACK_SECRET=CHANGE_ME_CALLBACK_SECRET
TRANSCRIPTION_CALLBACK_TIMEOUT=30
TRANSCRIPTION_CALLBACK_MAX_RETRIES=5

# --- The GPU worker intentionally has NO database and NO OSS credentials ---
# (ADR: split head/GPU/tail). Leave DATABASE_URL and OSS_* unset here.
