'use client';

import { useState, useEffect, useRef, useCallback } from 'react';
import { useParams, useRouter } from 'next/navigation';
import { api, getToken, mediaUrl } from '@/lib/api';
import type { VideoWithSubtitles } from '@/types';
import { cn, formatTime } from '@/lib/utils';
import {
  ArrowLeft,
  Languages,
  Mic,
  MicOff,
  Play,
  Pause,
  RotateCcw,
  Send,
  X,
  ChevronUp,
  ChevronDown,
  SkipForward,
  SkipBack,
  Loader2,
  Zap,
} from 'lucide-react';

type SpeakingState = 'idle' | 'listening' | 'reviewing' | 'submitting' | 'result';

interface SpeakingResult {
  accuracy: number;
  fluency: number;
  completeness: number;
  feedback: string;
  transcript: string;
}

const QUALITY_OPTIONS = [
  { key: 'video_url_480p', label: '480p' },
  { key: 'video_url_720p', label: '720p' },
  { key: 'video_url_1080p', label: '1080p' },
] as const;

type QualityKey = (typeof QUALITY_OPTIONS)[number]['key'];

export default function WatchPage() {
  const { id } = useParams<{ id: string }>();
  const router = useRouter();
  const videoRef = useRef<HTMLVideoElement>(null);
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const chunksRef = useRef<Blob[]>([]);

  const [video, setVideo] = useState<VideoWithSubtitles | null>(null);
  const [currentSubtitleIndex, setCurrentSubtitleIndex] = useState(0);
  const [selectedWord, setSelectedWord] = useState<string | null>(null);
  const [wordMeaning, setWordMeaning] = useState<string | null>(null);
  const [showEnglishOnly, setShowEnglishOnly] = useState(false);
  const [showShortcuts, setShowShortcuts] = useState(false);

  // Video quality
  const [quality, setQuality] = useState<QualityKey>('video_url_720p');
  const currentVideoUrl = video ? (video[quality] || video.video_url_720p || video.video_url_480p) : null;

  // Speaking state
  const [speakingState, setSpeakingState] = useState<SpeakingState>('idle');
  const [activeSubtitleId, setActiveSubtitleId] = useState<string | null>(null);
  const [audioUrl, setAudioUrl] = useState<string | null>(null);
  const [speakingResult, setSpeakingResult] = useState<SpeakingResult | null>(null);

  const activeSubtitle = video?.subtitles.find((s) => s.id === activeSubtitleId);

  useEffect(() => {
    if (!getToken()) { router.push('/login'); return; }
    api<VideoWithSubtitles>(/api/v1/videos/)
      .then((v) => setVideo(v))
      .catch((err) => {
        if (err.message?.includes('401')) router.push('/login');
      });
  }, [id, router]);

  // Auto-scroll subtitle
  useEffect(() => {
    const el = document.getElementById(subtitle-);
    el?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, [currentSubtitleIndex]);

  // Keyboard shortcuts
  useEffect(() => {
    function handleKey(e: KeyboardEvent) {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      switch (e.key) {
        case ' ':
          e.preventDefault();
          videoRef.current?.paused ? videoRef.current?.play() : videoRef.current?.pause();
          break;
        case 'ArrowLeft':
          if (videoRef.current) videoRef.current.currentTime = Math.max(0, videoRef.current.currentTime - 5);
          break;
        case 'ArrowRight':
          if (videoRef.current) videoRef.current.currentTime += 5;
          break;
        case 'ArrowUp':
          if (video?.subtitles) {
            const prev = Math.max(0, currentSubtitleIndex - 1);
            setCurrentSubtitleIndex(prev);
            seekTo(video.subtitles[prev].start_time);
          }
          break;
        case 'ArrowDown':
          if (video?.subtitles) {
            const next = Math.min(video.subtitles.length - 1, currentSubtitleIndex + 1);
            setCurrentSubtitleIndex(next);
            seekTo(video.subtitles[next].start_time);
          }
          break;
      }
    }
    window.addEventListener('keydown', handleKey);
    return () => window.removeEventListener('keydown', handleKey);
  }, [video, currentSubtitleIndex]);

  // Video time sync
  function seekTo(time: number) {
    if (videoRef.current) {
      videoRef.current.currentTime = time;
      videoRef.current.play();
    }
  }

  async function handleWordClick(word: string) {
    const clean = word.replace(/[.,!?;:'"]/g, '');
    if (selectedWord === clean) {
      setSelectedWord(null);
      setWordMeaning(null);
    } else {
      setSelectedWord(clean);
      setWordMeaning(null);
      // TTS
      const u = new SpeechSynthesisUtterance(clean);
      u.lang = 'en-US';
      speechSynthesis.cancel();
      speechSynthesis.speak(u);
      // Fetch meaning
      try {
        const ctx = video?.subtitles.find((s) => s.text_en.includes(clean));
        if (ctx) {
          const res = await api<{ meaning: string }>('/api/v1/ai/word-lookup', {
            });
          setWordMeaning(res.meaning);
        }
      } catch {}
    }
  }

  // --- Speaking Practice ---

  function startSpeaking(subtitleId: string) {
    setActiveSubtitleId(subtitleId);
    setSpeakingState('idle');
    setSpeakingResult(null);
    if (audioUrl) URL.revokeObjectURL(audioUrl);
    setAudioUrl(null);
  }

  function stopSpeaking() {
    setActiveSubtitleId(null);
    setSpeakingState('idle');
    setSpeakingResult(null);
    if (audioUrl) URL.revokeObjectURL(audioUrl);
    setAudioUrl(null);
  }

  async function startRecording() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      const recorder = new MediaRecorder(stream, { mimeType: 'audio/webm' });
      mediaRecorderRef.current = recorder;
      chunksRef.current = [];

      recorder.ondataavailable = (e) => {
        if (e.data.size > 0) chunksRef.current.push(e.data);
      };

      recorder.onstop = () => {
        const blob = new Blob(chunksRef.current, { type: 'audio/webm' });
        const url = URL.createObjectURL(blob);
        setAudioUrl(url);
        setSpeakingState('reviewing');
        stream.getTracks().forEach((t) => t.stop());
      };

      recorder.start();
      setSpeakingState('listening');
    } catch {
      alert('╬▐Ę©Ę├╬╩┬¾┐╦ĘńŻ¼Ūļ╝ņ▓ķõ»└└Ų„╚©Ž▐ĪŻ');
    }
  }

  function stopRecording() {
    mediaRecorderRef.current?.stop();
  }

  async function submitForFeedback() {
    if (!audioUrl || !activeSubtitleId) return;
    setSpeakingState('submitting');

    try {
      const blob = await fetch(audioUrl).then((r) => r.blob());
      const form = new FormData();
      form.append('audio', blob, 'recording.webm');
      form.append('subtitle_id', activeSubtitleId);

      const result = await api<SpeakingResult>('/api/v1/speaking/practice', {
        method: 'POST',
        body: form,
        headers: {} as Record<string, string>,
      });

      setSpeakingResult(result);
      setSpeakingState('result');
    } catch (err) {
      alert(err instanceof Error ? err.message : '╠ßĮ╗╩¦░▄');
      setSpeakingState('reviewing');
    }
  }

  function reRecord() {
    if (audioUrl) URL.revokeObjectURL(audioUrl);
    setAudioUrl(null);
    setSpeakingState('idle');
    setSpeakingResult(null);
  }

  // --- Render ---

  if (!video) {
    return (
      <main className="flex min-h-screen items-center justify-center">
        <Loader2 size={24} className="animate-spin text-brand-600" />
      </main>
    );
  }

  if (video.status === 'processing') {
    return (
      <main className="flex min-h-screen items-center justify-center">
        <div className="text-center">
          <div className="mx-auto h-12 w-12 animate-spin rounded-full border-2 border-brand-600 border-t-transparent" />
          <p className="mt-4 text-slate-600">╩ėŲĄ┤”└ĒųąŻ¼┤¾į╝ąĶę¬ 1-2 Ęųųė...</p>
          <p className="mt-1 text-sm text-slate-400">AI š²į┌╠ß╚Īūų─╗ĪóĘŁęļĪó│÷╠Ō</p>
        </div>
      </main>
    );
  }

  if (video.status === 'error') {
    return (
      <main className="flex min-h-screen items-center justify-center">
        <div className="text-center">
          <p className="text-slate-600">┤”└Ē╩¦░▄</p>
          <p className="mt-1 text-sm text-red-500">{video.error_message || '╬┤ų¬┤Ē╬¾'}</p>
          <button
            onClick={() => router.push('/dashboard')}
            className="mt-4 text-sm text-brand-600 hover:underline"
          >
            ĘĄ╗ž╩ėŲĄ┐Ō
          </button>
        </div>
      </main>
    );
  }

  return (
    <main className="flex h-[calc(100vh-64px)] flex-col">
      {/* Top bar */}
      <div className="flex items-center gap-3 border-b border-slate-200 bg-white px-4 py-2.5">
        <button
          onClick={() => router.push('/dashboard')}
          className="flex items-center gap-1 rounded-md px-2 py-1 text-sm text-slate-500 hover:bg-slate-100 hover:text-slate-700"
        >
          <ArrowLeft size={16} />
        </button>
        <h1 className="flex-1 truncate text-sm font-medium text-slate-900">{video.title}</h1>

        {/* Quality selector */}
        <select
          value={quality}
          onChange={(e) => setQuality(e.target.value as QualityKey)}
          className="rounded-md border border-slate-200 bg-white px-2 py-1 text-xs text-slate-600"
        >
          {QUALITY_OPTIONS.map((q) => (
            video[q.key] ? <option key={q.key} value={q.key}>{q.label}</option> : null
          ))}
        </select>

        <button
          onClick={() => setShowEnglishOnly(!showEnglishOnly)}
          className={cn(
            'flex items-center gap-1 rounded-md px-3 py-1 text-xs font-medium border',
            showEnglishOnly
              ? 'bg-brand-50 text-brand-700 border-brand-200'
              : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'
          )}
        >
          <Languages size={14} />
          {showEnglishOnly ? '┤┐ėó╬─' : '╦½ė’'}
        </button>

        <button
          onClick={() => setShowShortcuts(!showShortcuts)}
          className="rounded-md px-2 py-1 text-xs text-slate-400 hover:bg-slate-100 hover:text-slate-600"
        >
          <Zap size={14} />
        </button>
      </div>

      {/* Shortcuts tooltip */}
      {showShortcuts && (
        <div className="absolute right-4 top-16 z-20 w-56 rounded-xl border border-slate-200 bg-white p-4 shadow-lg">
          <div className="flex items-center justify-between mb-2">
            <p className="text-xs font-semibold text-slate-700">╝³┼╠┐ņĮ▌╝³</p>
            <button onClick={() => setShowShortcuts(false)} className="text-slate-400 hover:text-slate-600">
              <X size={14} />
            </button>
          </div>
          <div className="space-y-1.5 text-xs text-slate-600">
            <p><kbd className="rounded bg-slate-100 px-1 py-0.5 font-mono">Space</kbd> į▌═Ż/▓źĘ┼</p>
            <p><kbd className="rounded bg-slate-100 px-1 py-0.5 font-mono">Ī¹Ī·</kbd> ║¾═╦/Ū░Į° 5s</p>
            <p><kbd className="rounded bg-slate-100 px-1 py-0.5 font-mono">Ī³Ī²</kbd> ╔Žę╗Šõ/Ž┬ę╗Šõ</p>
          </div>
        </div>
      )}

      <div className="flex flex-1 overflow-hidden">
        {/* Video area */}
        <div className="flex w-full flex-col bg-black lg:w-3/5">
          <div className="flex flex-1 items-center justify-center">
            {currentVideoUrl ? (
              <video
                ref={videoRef}
                src={mediaUrl(currentVideoUrl)}
                controls
                className="max-h-full max-w-full"
                onTimeUpdate={(e) => {
                  const t = e.currentTarget.currentTime;
                  const idx = video.subtitles.findIndex(
                    (s) => t >= s.start_time && t <= s.end_time
                  );
                  if (idx !== -1) setCurrentSubtitleIndex(idx);
                }}
              />
            ) : (
              <div className="text-center">
                <Play size={40} className="mx-auto text-slate-600" />
                <p className="mt-3 text-sm text-slate-500">╩ėŲĄ╬┤Š═ą„</p>
              </div>
            )}
          </div>

          {/* Speaking practice bar */}
          {activeSubtitleId && activeSubtitle && (
            <div className="border-t border-slate-700 bg-slate-900 px-4 py-4">
              <div className="flex items-center gap-3">
                <button onClick={stopSpeaking} className="text-slate-400 hover:text-white">
                  <X size={18} />
                </button>
                <p className="flex-1 text-sm text-slate-300 truncate">
                  ĪĖ{activeSubtitle.text_en}Ī╣
                </p>

                {speakingState === 'idle' && (
                  <button
                    onClick={startRecording}
                    className="inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700"
                  >
                    <Mic size={16} /> ┐¬╩╝Ė·Č┴
                  </button>
                )}
                {speakingState === 'listening' && (
                  <button
                    onClick={stopRecording}
                    className="inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white animate-pulse"
                  >
                    <MicOff size={16} /> ═Żų╣┬╝ę¶
                  </button>
                )}
                {speakingState === 'reviewing' && (
                  <div className="flex gap-2">
                    <button
                      onClick={reRecord}
                      className="inline-flex items-center gap-1 rounded-lg border border-slate-500 px-3 py-2 text-sm text-slate-300 hover:text-white"
                    >
                      <RotateCcw size={14} /> ųž┬╝
                    </button>
                    <button
                      onClick={submitForFeedback}
                      className="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700"
                    >
                      <Send size={14} /> ╠ßĮ╗Ų└Ęų
                    </button>
                  </div>
                )}
              </div>

              {/* Audio playback */}
              {audioUrl && (
                <div className="mt-3">
                  <p className="mb-1 text-xs text-slate-400">─ŃĄ─┬╝ę¶Ż║</p>
                  <audio src={audioUrl} controls className="h-8 w-full max-w-md" />
                </div>
              )}

              {/* AI Feedback */}
              {speakingState === 'submitting' && (
                <p className="mt-3 text-sm text-slate-400">AI š²į┌Ų└Ęų...</p>
              )}
              {speakingResult && speakingState === 'result' && (
                <div className="mt-3 rounded-lg bg-slate-800 p-3">
                  <div className="flex gap-4 text-xs">
                    <span className="text-green-400">ū╝╚ĘČ╚ {speakingResult.accuracy}%</span>
                    <span className="text-blue-400">┴„└¹Č╚ {speakingResult.fluency}%</span>
                    <span className="text-yellow-400">═Ļš¹Č╚ {speakingResult.completeness}%</span>
                  </div>
                  <p className="mt-2 text-sm text-slate-300">{speakingResult.feedback}</p>
                  <button onClick={reRecord} className="mt-2 text-xs text-brand-400 hover:underline">
                    į┘╩įę╗┤╬ Ī·
                  </button>
                </div>
              )}
            </div>
          )}
        </div>

        {/* Subtitle panel */}
        <div className="w-full overflow-y-auto border-l border-slate-200 bg-white lg:w-2/5">
          <div className="divide-y divide-slate-100">
            {video.subtitles.map((sub, i) => {
              const isActive = i === currentSubtitleIndex;
              return (
                <div
                  key={sub.id}
                  id={subtitle-}
                  className={cn(
                    'transition-colors',
                    isActive && 'bg-brand-50 border-l-2 border-l-brand-500'
                  )}
                >
                  <button
                    onClick={() => { setCurrentSubtitleIndex(i); seekTo(sub.start_time); }}
                    className="w-full px-4 py-3 text-left hover:bg-slate-50"
                  >
                    <p className="text-xs text-slate-400">{formatTime(sub.start_time)}</p>
                    <p className="mt-1 text-sm leading-relaxed text-slate-900">
                      {sub.text_en.split(' ').map((word, wi) => (
                        <span
                          key={wi}
                          onClick={(e) => { e.stopPropagation(); handleWordClick(word); }}
                          className={cn(
                            'cursor-pointer rounded hover:bg-brand-100',
                            selectedWord === word.replace(/[.,!?;:'"]/g, '') && 'bg-brand-200'
                          )}
                        >
                          {word}{' '}
                        </span>
                      ))}
                    </p>
                    {!showEnglishOnly && sub.text_zh && (
                      <p className="mt-1 text-sm text-slate-500">{sub.text_zh}</p>
                    )}
                    {sub.grammar_note && (
                      <p className="mt-1 text-xs text-amber-600">?? {sub.grammar_note}</p>
                    )}
                  </button>

                  {/* Practice button */}
                  <div className="px-4 pb-2">
                    <button
                      onClick={() => startSpeaking(sub.id)}
                      className="inline-flex items-center gap-1 text-xs text-brand-600 hover:underline"
                    >
                      <Mic size={12} /> Ė·Č┴šŌŠõ
                    </button>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      {/* Word popup */}
      {selectedWord && (
        <div className="fixed bottom-4 right-4 w-80 rounded-xl border border-slate-200 bg-white p-4 shadow-xl z-30">
          <div className="flex items-center justify-between">
            <h3 className="text-lg font-bold text-slate-900">{selectedWord}</h3>
            <button onClick={() => { setSelectedWord(null); setWordMeaning(null); }} className="text-slate-400 hover:text-slate-600">
              <X size={16} />
            </button>
          </div>
          <button
            onClick={() => {
              const u = new SpeechSynthesisUtterance(selectedWord);
              u.lang = 'en-US';
              speechSynthesis.cancel();
              speechSynthesis.speak(u);
            }}
            className="mt-2 inline-flex items-center gap-1 text-xs text-brand-600 hover:underline"
          >
            ?? └╩Č┴
          </button>
          {wordMeaning ? (
            <p className="mt-2 text-sm text-slate-700">{wordMeaning}</p>
          ) : (
            <p className="mt-2 text-xs text-slate-400">╝ėįžųą...</p>
          )}
        </div>
      )}
    </main>
  );
}


"use client";

import { useState, useEffect, useRef, useCallback } from "react";
import { useParams, useRouter } from "next/navigation";
import { api, getToken, mediaUrl } from "@/lib/api";
import type { VideoWithSubtitles } from "@/types";
import { cn, formatTime } from "@/lib/utils";

type SpeakingState = "idle" | "listening" | "reviewing" | "submitting" | "result";

interface SpeakingResult {
  accuracy: number;
  fluency: number;
  completeness: number;
  feedback: string;
  transcript: string;
}

export default function WatchPage() {
  const { id } = useParams<{ id: string }>();
  const router = useRouter();
  const videoRef = useRef<HTMLVideoElement>(null);
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const chunksRef = useRef<Blob[]>([]);

  const [video, setVideo] = useState<VideoWithSubtitles | null>(null);
  const [currentSubtitleIndex, setCurrentSubtitleIndex] = useState(0);
  const [selectedWord, setSelectedWord] = useState<string | null>(null);
  const [showEnglishOnly, setShowEnglishOnly] = useState(false);

  // Speaking state
  const [speakingState, setSpeakingState] = useState<SpeakingState>("idle");
  const [activeSubtitleId, setActiveSubtitleId] = useState<string | null>(null);
  const [audioUrl, setAudioUrl] = useState<string | null>(null);
  const [speakingResult, setSpeakingResult] = useState<SpeakingResult | null>(null);
  const [originalAudioPlaying, setOriginalAudioPlaying] = useState(false);

  const activeSubtitle = video?.subtitles.find((s) => s.id === activeSubtitleId);

  useEffect(() => {
    if (!getToken()) { router.push("/login"); return; }
    api<VideoWithSubtitles>(`/api/v1/videos/${id}`)
      .then((v) => setVideo(v))
      .catch((err) => {
        if (err.message?.includes("401")) router.push("/login");
      });
  }, [id, router]);

  // Auto-scroll
  useEffect(() => {
    const el = document.getElementById(`subtitle-${currentSubtitleIndex}`);
    el?.scrollIntoView({ behavior: "smooth", block: "center" });
  }, [currentSubtitleIndex]);

  // Video time sync
  function seekTo(time: number) {
    if (videoRef.current) {
      videoRef.current.currentTime = time;
      videoRef.current.play();
    }
  }

  function handleWordClick(word: string) {
    setSelectedWord(selectedWord === word ? null : word);
    const u = new SpeechSynthesisUtterance(word);
    u.lang = "en-US";
    speechSynthesis.cancel();
    speechSynthesis.speak(u);
  }

  // --- Speaking Practice ---

  function startSpeaking(subtitleId: string) {
    setActiveSubtitleId(subtitleId);
    setSpeakingState("idle");
    setSpeakingResult(null);
    setAudioUrl(null);
  }

  function stopSpeaking() {
    setActiveSubtitleId(null);
    setSpeakingState("idle");
    setSpeakingResult(null);
    if (audioUrl) URL.revokeObjectURL(audioUrl);
    setAudioUrl(null);
  }

  async function playOriginalAudio() {
    if (!activeSubtitle) return;
    setOriginalAudioPlaying(true);
    const u = new SpeechSynthesisUtterance(activeSubtitle.text_en);
    u.lang = "en-US";
    u.rate = 0.9;
    u.onend = () => setOriginalAudioPlaying(false);
    speechSynthesis.cancel();
    speechSynthesis.speak(u);
  }

  async function startRecording() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      const recorder = new MediaRecorder(stream, { mimeType: "audio/webm" });
      mediaRecorderRef.current = recorder;
      chunksRef.current = [];

      recorder.ondataavailable = (e) => {
        if (e.data.size > 0) chunksRef.current.push(e.data);
      };

      recorder.onstop = () => {
        const blob = new Blob(chunksRef.current, { type: "audio/webm" });
        const url = URL.createObjectURL(blob);
        setAudioUrl(url);
        setSpeakingState("reviewing");
        stream.getTracks().forEach((t) => t.stop());
      };

      recorder.start();
      setSpeakingState("listening");
    } catch {
      alert("µŚĀµ│ĢĶ«┐ķŚ«ķ║”ÕģŗķŻÄ’╝īĶ»ĘµŻĆµ¤źµĄÅĶ¦łÕÖ©µØāķÖÉŃĆ?);
    }
  }

  function stopRecording() {
    mediaRecorderRef.current?.stop();
  }

  async function submitForFeedback() {
    if (!audioUrl || !activeSubtitleId) return;
    setSpeakingState("submitting");

    try {
      const blob = await fetch(audioUrl).then((r) => r.blob());
      const form = new FormData();
      form.append("audio", blob, "recording.webm");
      form.append("subtitle_id", activeSubtitleId);

      const result = await api<SpeakingResult>("/api/v1/speaking/practice", {
        method: "POST",
        body: form,
        headers: {} as Record<string, string>,
      });

      setSpeakingResult(result);
      setSpeakingState("result");
    } catch (err) {
      alert(err instanceof Error ? err.message : "µÅÉõ║żÕż▒Ķ┤ź");
      setSpeakingState("reviewing");
    }
  }

  function reRecord() {
    if (audioUrl) URL.revokeObjectURL(audioUrl);
    setAudioUrl(null);
    setSpeakingState("idle");
    setSpeakingResult(null);
  }

  // --- Render ---

  if (!video) {
    return (
      <main className="flex min-h-screen items-center justify-center">
        <p className="text-slate-500">ÕŖĀĶĮĮõĖ?..</p>
      </main>
    );
  }

  if (video.status === "processing") {
    return (
      <main className="flex min-h-screen items-center justify-center">
        <div className="text-center">
          <div className="mx-auto h-8 w-8 animate-spin rounded-full border-2 border-brand-600 border-t-transparent" />
          <p className="mt-4 text-slate-600">Ķ¦åķóæÕżäńÉåõĖŁ’╝īÕż¦ń║”ķ£ĆĶ”?1-2 ÕłåķÆ¤...</p>
        </div>
      </main>
    );
  }

  return (
    <main className="flex h-screen flex-col">
      {/* Top bar */}
      <div className="flex items-center gap-4 border-b px-4 py-3">
        <button onClick={() => router.push("/dashboard")} className="text-sm text-slate-500 hover:text-slate-700">
          Ōå?Ķ┐öÕø×
        </button>
        <h1 className="flex-1 truncate text-sm font-medium text-slate-900">{video.title}</h1>
        <button
          onClick={() => setShowEnglishOnly(!showEnglishOnly)}
          className={cn(
            "rounded-md px-3 py-1 text-xs font-medium border",
            showEnglishOnly ? "bg-brand-50 text-brand-700 border-brand-200" : "bg-white text-slate-600 border-slate-200"
          )}
        >
          {showEnglishOnly ? "ń║»Ķŗ▒µ¢? : "ÕÅīĶ»Ł"}
        </button>
      </div>

      <div className="flex flex-1 overflow-hidden">
        {/* Video area */}
        <div className="flex w-full flex-col bg-black lg:w-3/5">
          <div className="flex flex-1 items-center justify-center">
            {video.video_url_720p ? (
              <video
                ref={videoRef}
                src={mediaUrl(video.video_url_720p!)}
                controls
                className="max-h-full max-w-full"
                onTimeUpdate={(e) => {
                  const t = e.currentTarget.currentTime;
                  const idx = video.subtitles.findIndex(
                    (s) => t >= s.start_time && t <= s.end_time
                  );
                  if (idx !== -1) setCurrentSubtitleIndex(idx);
                }}
              />
            ) : (
              <p className="text-slate-400">Ķ¦åķóæÕćåÕżćõĖ?..</p>
            )}
          </div>

          {/* Speaking practice bar */}
          {activeSubtitleId && activeSubtitle && (
            <div className="border-t border-slate-700 bg-slate-900 px-4 py-4">
              <div className="flex items-center gap-3">
                <button onClick={stopSpeaking} className="text-slate-400 hover:text-white text-sm">
                  Ō£?                </button>
                <p className="flex-1 text-sm text-slate-300 truncate">
                  ŃĆī{activeSubtitle.text_en}ŃĆ?                </p>

                {speakingState === "idle" && (
                  <button onClick={startRecording} className="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
                    ­¤Äż Õ╝ĆÕ¦ŗĶĘ¤Ķ»?                  </button>
                )}
                {speakingState === "listening" && (
                  <button onClick={stopRecording} className="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white animate-pulse">
                    ŌÅ?Õü£µŁóÕĮĢķ¤│
                  </button>
                )}
                {speakingState === "reviewing" && (
                  <div className="flex gap-2">
                    <button onClick={reRecord} className="rounded-lg border border-slate-500 px-3 py-2 text-sm text-slate-300 hover:text-white">
                      ķćŹÕĮĢ
                    </button>
                    <button onClick={submitForFeedback} className="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700">
                      µÅÉõ║żĶ»äÕłå
                    </button>
                  </div>
                )}
              </div>

              {/* Audio playback */}
              {audioUrl && (
                <div className="mt-3">
                  <p className="text-xs text-slate-400 mb-1">õĮĀńÜäÕĮĢķ¤│’╝?/p>
                  <audio src={audioUrl} controls className="h-8 w-full max-w-md" />
                </div>
              )}

              {/* AI Feedback result */}
              {speakingState === "submitting" && (
                <p className="mt-3 text-sm text-slate-400">AI µŁŻÕ£©Ķ»äÕłå...</p>
              )}
              {speakingResult && speakingState === "result" && (
                <div className="mt-3 rounded-lg bg-slate-800 p-3">
                  <div className="flex gap-4 text-xs">
                    <span className="text-green-400">ÕćåńĪ«Õ║?{speakingResult.accuracy}%</span>
                    <span className="text-blue-400">µĄüÕł®Õ║?{speakingResult.fluency}%</span>
                    <span className="text-yellow-400">Õ«īµĢ┤Õ║?{speakingResult.completeness}%</span>
                  </div>
                  <p className="mt-2 text-sm text-slate-300">{speakingResult.feedback}</p>
                  <button onClick={reRecord} className="mt-2 text-xs text-brand-400 hover:underline">
                    ÕåŹĶ»ĢõĖĆµ¼?Ōå?                  </button>
                </div>
              )}
            </div>
          )}
        </div>

        {/* Subtitle panel */}
        <div className="w-full overflow-y-auto border-l border-slate-200 bg-white lg:w-2/5">
          <div className="divide-y divide-slate-100">
            {video.subtitles.map((sub, i) => (
              <div
                key={sub.id}
                id={`subtitle-${i}`}
                className={cn(
                  "transition-colors",
                  i === currentSubtitleIndex && "bg-brand-50 border-l-2 border-l-brand-500"
                )}
              >
                <button
                  onClick={() => { setCurrentSubtitleIndex(i); seekTo(sub.start_time); }}
                  className="w-full px-4 py-3 text-left hover:bg-slate-50"
                >
                  <p className="text-xs text-slate-400">{formatTime(sub.start_time)}</p>
                  <p className="mt-1 text-sm text-slate-900 leading-relaxed">
                    {sub.text_en.split(" ").map((word, wi) => (
                      <span
                        key={wi}
                        onClick={(e) => { e.stopPropagation(); handleWordClick(word.replace(/[.,!?;:'"]/g, "")); }}
                        className={cn(
                          "cursor-pointer rounded hover:bg-brand-100",
                          selectedWord === word.replace(/[.,!?;:'"]/g, "") && "bg-brand-200"
                        )}
                      >
                        {word}{" "}
                      </span>
                    ))}
                  </p>
                  {!showEnglishOnly && sub.text_zh && (
                    <p className="mt-1 text-sm text-slate-500">{sub.text_zh}</p>
                  )}
                  {sub.grammar_note && (
                    <p className="mt-1 text-xs text-amber-600">­¤ÆĪ {sub.grammar_note}</p>
                  )}
                </button>

                {/* Practice button per subtitle */}
                <div className="px-4 pb-2">
                  <button
                    onClick={() => startSpeaking(sub.id)}
                    className="text-xs text-brand-600 hover:underline"
                  >
                    ­¤Äż ĶĘ¤Ķ»╗Ķ┐ÖÕÅź
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Word popup */}
      {selectedWord && (
        <div className="fixed bottom-4 right-4 w-72 rounded-xl border border-slate-200 bg-white p-4 shadow-lg z-10">
          <div className="flex items-center justify-between">
            <h3 className="text-lg font-bold text-slate-900">{selectedWord}</h3>
            <button onClick={() => setSelectedWord(null)} className="text-slate-400 hover:text-slate-600 text-xs">
              Ō£?            </button>
          </div>
          <button
            onClick={() => {
              const u = new SpeechSynthesisUtterance(selectedWord);
              u.lang = "en-US";
              speechSynthesis.cancel();
              speechSynthesis.speak(u);
            }}
            className="mt-2 text-xs text-brand-600 hover:underline"
          >
            ­¤öŖ µ£ŚĶ»╗
          </button>
          <p className="mt-1 text-xs text-slate-400">Pro õ╝ÜÕæśÕÅ»µ¤źń£?AI õĖŖõĖŗµ¢ćķćŖõ╣?/p>
        </div>
      )}
    </main>
  );
}

