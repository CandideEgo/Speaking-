# Frontend 环境变量示例。复制为 .env.local 后按需填写。
# 后端 API 地址（留空则回退到 http://localhost:8000）
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== ICP 合规与运营配置 =====
# 个体户无 ICP 经营许可证，网站为非经营性工具展示平台，不在站内收款。
# 会员通过微信小商店购买后用兑换码激活。取得备案/开店后填入以下变量，
# 留空时前端按"备案/开店中"占位渲染。
NEXT_PUBLIC_MINI_STORE_URL=
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_COMPANY_USCC=
NEXT_PUBLIC_ICP_BEIAN=
NEXT_PUBLIC_POLICE_BEIAN=
